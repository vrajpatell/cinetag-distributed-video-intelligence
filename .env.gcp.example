APP_ENV=gcp
GCP_PROJECT_ID=cinetag-distributed-video
GCP_REGION=us-central1
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=cinetag-distributed-video-media
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://cinetag_app:${DATABASE_PASSWORD}@/<DB_NAME>?host=/cloudsql/<INSTANCE_CONNECTION_NAME>
CLOUD_SQL_CONNECTION_NAME=cinetag-distributed-video:us-central1:cinetag-postgres
QUEUE_BACKEND=redis
REDIS_URL=redis://<MEMORYSTORE_REDIS_PRIVATE_IP>:6379/0
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
SECRET_MANAGER_ENABLED=true
LOG_LEVEL=INFO
OTEL_ENABLED=false
CORS_ALLOWED_ORIGINS=https://<cinetag-frontend-url>
FRONTEND_URL=<filled-after-deploy>
API_BASE_URL=<filled-after-deploy>
